{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Veridian Health Partners",
  "description": "Healthcare infrastructure for jails and correctional settings. Veridian Health delivers AI-assisted PT assessments with PT-driven recommendations. Additional products at veridianhp.com.",
  "colors": {
    "primary": "#2DD4BF",
    "light": "#5DEFE0",
    "dark": "#0E9994"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/veridian-shield.jpg",
    "dark": "/logo/veridian-shield.jpg",
    "href": "https://veridianhp.com"
  },
  "navigation": {
    "groups": [
      {
        "group": "Veridian Health Partners",
        "icon": "building",
        "pages": [
          "introduction"
        ]
      },
      {
        "group": "Veridian Health",
        "icon": "heart-pulse",
        "pages": [
          "veridian-health/overview",
          "veridian-health/how-it-works",
          "veridian-health/for-facilities",
          "veridian-health/for-providers",
          "veridian-health/quickstart"
        ]
      },
      {
        "group": "Veridian Billing",
        "icon": "receipt",
        "pages": [
          "veridian-billing/overview"
        ]
      },
      {
        "group": "Security & compliance",
        "icon": "shield-check",
        "pages": [
          "security/overview",
          "security/hipaa",
          "security/data-handling",
          "security/incident-response"
        ]
      },
      {
        "group": "Support",
        "icon": "life-ring",
        "pages": [
          "troubleshooting",
          "faq",
          "changelog"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://veridianhp.com",
          "icon": "globe"
        },
        {
          "anchor": "Status",
          "href": "https://status.veridianhp.com",
          "icon": "signal-stream"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "https://veridianhp.com/contact"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Request access",
      "href": "https://veridianhp.com/request-access"
    }
  },
  "footer": {
    "socials": {
      "website": "https://veridianhp.com"
    }
  }
