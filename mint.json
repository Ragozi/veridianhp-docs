      "name": "API Reference",
      "icon": "code",
      "url": "api"
    },
    {
      "name": "Security",
      "icon": "shield-check",
      "url": "security"
    },
    {
      "name": "Status",
      "icon": "signal-stream",
      "url": "https://status.veridianhp.com"
    }
